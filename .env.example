EDUWORK_ENVIRONMENT=development
EDUWORK_DATABASE_URL=postgresql+psycopg://eduwork:eduwork@postgres:5432/eduwork
EDUWORK_LOG_LEVEL=INFO
EDUWORK_DEMO_MODE=true
EDUWORK_RAW_STORE_ROOT=var/raw
EDUWORK_EXPORT_ROOT=var/exports
EDUWORK_LINEAGE_ROOT=var/lineage
EDUWORK_MAX_SOURCE_BYTES=104857600
EDUWORK_MAX_REQUEST_BYTES=5242880
EDUWORK_RATE_LIMIT_PER_MINUTE=120
EDUWORK_RAW_RETENTION_DAYS=30
EDUWORK_EXPORT_RETENTION_DAYS=30
EDUWORK_DEMO_IDENTITY_ENABLED=true
EDUWORK_TELEMETRY_ENABLED=true
EDUWORK_ALLOW_PRIVATE_NETWORK_SOURCES=false
# Set only in a private environment; never commit values.
# EDUWORK_DEMO_REST_TOKEN=
# EDUWORK_DEMO_POSTGRES_URL=
